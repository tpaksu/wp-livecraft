{
	"name": "frontend-block-editor",
	"version": "0.1.4",
	"private": true,
	"description": "Edit WordPress block content inline on the frontend",
	"scripts": {
		"build": "wp-scripts build",
		"start": "wp-scripts start",
		"lint:js": "wp-scripts lint-js src/",
		"lint:js:fix": "wp-scripts lint-js src/ --fix",
		"lint:css": "wp-scripts lint-style 'src/**/*.scss'",
		"lint:css:fix": "wp-scripts lint-style 'src/**/*.scss' --fix",
		"lint:php": "composer phpcs",
		"lint:php:fix": "composer phpcbf",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:php",
		"release": "git archive --format=zip --prefix=frontend-block-editor/ -o frontend-block-editor.zip HEAD"
	},
	"devDependencies": {
		"@wordpress/icons": "^12.2.0",
		"@wordpress/media-utils": "^5.44.0",
		"@wordpress/scripts": "^30.0.0"
	}
}
